# Copy to local.properties (gitignored) and set your Android SDK path.
# Linux typical: /home/YOU/Android/Sdk
# macOS typical: /Users/YOU/Library/Android/sdk
sdk.dir=/path/to/Android/sdk

# Optional Plum TV dev defaults.
# plumTv.defaultServerUrl=http://YOUR_PLUM_SERVER:8080
# plumTv.defaultAdminEmail=admin@example.com
# plumTv.defaultAdminPassword=

# Optional: sign release builds locally (path relative to apps/android-tv/app/). Do not commit keystore files.
# plumTv.releaseStoreFile=my-release.keystore
# plumTv.releaseStorePassword=
# plumTv.releaseKeyAlias=
# plumTv.releaseKeyPassword=
