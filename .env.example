# TMDb API Key for fetching TV/Movie metadata
TMDB_API_KEY=
# TVDB Api Key for fetching TV/Movie Metadata
TVDB_API_KEY=
# OMDB API Key for fetching TV/Movie Metadata
OMDB_API_KEY=
# Fanart.tv API Key for fetching poster artwork
FANART_API_KEY=

# Media stack integrations for Discover add/download activity.
# When running Plum on your host machine, point these at local services or SSH
# tunnels. When running Plum in Docker, use a reachable host name such as
# host.docker.internal instead of 127.0.0.1.
PLUM_RADARR_BASE_URL=
PLUM_RADARR_API_KEY=
# PLUM_RADARR_API_KEY_FILE=
PLUM_RADARR_QUALITY_PROFILE_ID=
PLUM_RADARR_ROOT_FOLDER_PATH=
PLUM_RADARR_SEARCH_ON_ADD=true

PLUM_SONARR_TV_BASE_URL=
PLUM_SONARR_TV_API_KEY=
# PLUM_SONARR_TV_API_KEY_FILE=
PLUM_SONARR_TV_QUALITY_PROFILE_ID=
PLUM_SONARR_TV_ROOT_FOLDER_PATH=
PLUM_SONARR_TV_SEARCH_ON_ADD=true

# Optional: explicit .env path for read/write (defaults to .env then ../.env from the server cwd).
# PLUM_DOTENV_PATH=

# Paths and Ports
PLUM_ADDR=:8080
# SQLite database file path (default: ./data/plum.db). In Docker use /data/plum.db.
PLUM_DATABASE_URL=./data/plum.db
# Libraries are added via onboarding or settings; no auto-scan path.

# Frontend settings
# For Compose dev, this is the browser-facing backend origin used for both API
# and WebSocket requests. Leave it unset to use the Vite proxy on :5173.
# VITE_BACKEND_URL=http://localhost:8080
# Optional: serve HLS/transcode segments straight from the Go server so high
# segment volume does not go through the Vite proxy (same hostname as the app
# is recommended, e.g. localhost + localhost:8080).
# VITE_PLAYBACK_STREAM_BASE=http://localhost:8080
# When VITE_BACKEND_URL is unset, the frontend dev server proxies to this
# internal backend target.
BACKEND_INTERNAL_URL=http://localhost:8080
