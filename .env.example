# TMDb API Key for fetching TV/Movie metadata
TMDB_API_KEY=
# TVDB Api Key for fetching TV/Movie Metadata
TVDB_API_KEY=
# OMDB API Key for fetching TV/Movie Metadata
OMDB_API_KEY=
# Fanart.tv API Key for fetching poster artwork
FANART_API_KEY=

# Paths and Ports
PLUM_ADDR=:8080
# SQLite database file path (default: ./data/plum.db). In Docker use /data/plum.db.
PLUM_DATABASE_URL=./data/plum.db
# Host media library paths used by the app and Docker compose mounts.
# Update these to match your machine.
PLUM_MEDIA_TV_PATH=/storage/media/tv
PLUM_MEDIA_MOVIES_PATH=/storage/media/movies
PLUM_MEDIA_ANIME_PATH=/storage/media/anime-series
PLUM_MEDIA_MUSIC_PATH=/storage/media/music

# Frontend settings
# For Compose dev, this is the browser-facing backend origin used for both API
# and WebSocket requests. Leave it unset to use the Vite proxy on :5173.
VITE_BACKEND_URL=http://localhost:8080
# When VITE_BACKEND_URL is unset, the frontend dev server proxies to this
# internal backend target.
# BACKEND_INTERNAL_URL=http://app:8080
